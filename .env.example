# ─────────────────────────────────────────────────────────────
# Fennec Management System — environment variables (NAMES ONLY)
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────

# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (service role). NEVER expose to the client.
# Used only by lib/supabase/admin.ts (import 'server-only') for the
# import wizard and scheduled jobs.
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (added in Phase 6)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
